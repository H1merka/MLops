AIRFLOW_UID=1000
AIRFLOW_GID=0

AIRFLOW_IMAGE_NAME=apache/airflow:3.1.2

_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

AIRFLOW__API_AUTH__JWT_SECRET=change_me_jwt_secret
AIRFLOW__API__SECRET_KEY=change_me_api_secret

# Connection for DAG 02 (CarsHook)
AIRFLOW_CONN_CARSAPI=http://airflow:airflow@carsapi:8081

# Credentials used by cars-api service
API_USER=airflow
API_PASSWORD=airflow

# Credentials/host used by DAG 01 requests
CARS_HOST=carsapi
CARS_SCHEMA=http
CARS_PORT=8081
CARS_USER=airflow
CARS_PASSWORD=airflow

# Quick local dependency injection into Airflow image
_PIP_ADDITIONAL_REQUIREMENTS="pandas==2.2.3 requests==2.32.3 scikit-learn==1.6.1"

# From Airflow 3.0.2, the `dags` folder (a.k.a. the DagBundle) is no longer automatically included on the PYTHONPATH
# This means that in order to use our custom Python modules, we need to install the custom directory. We also
# added a small `setup.py` to make this work, as well as volume mounts in the compose override.
# _PIP_ADDITIONAL_REQUIREMENTS="/opt/airflow/custom/"
